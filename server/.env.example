# ─── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/gtm-automation?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── OpenAI (fallback) ──────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ─── Groq (primary for fast tasks) ────────────────────
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Mistral (primary for reasoning tasks, fallback) ──
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-large-latest

# ─── Redis (optional - session/cache) ────────────────────
REDIS_URL=redis://localhost:6379

# ─── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=debug

# ─── Scraping ────────────────────────────────────────────
SCRAPING_TIMEOUT=15000
SCRAPING_RETRIES=3

# ─── Job Queue ───────────────────────────────────────────
MAX_JOB_RETRIES=3
JOB_RETRY_DELAY_MS=5000

# ─── Resume ──────────────────────────────────────────────
RESUME_MAX_SIZE_MB=5
UPLOAD_DIR=./uploads
